ANTHROPIC_API_KEY=sk-ant-...
APPROVAL_THRESHOLD_USD=10000

# Rutas de SQLite. En local pueden quedar así.
# En Railway/producción apuntar a un volumen persistente, ej:
#   CHECKPOINT_DB_PATH=/data/quoteflow.db
#   DATABASE_PATH=/data/quoteflow_meta.db
CHECKPOINT_DB_PATH=./quoteflow.db
DATABASE_PATH=./quoteflow.db

# Origen del frontend permitido por CORS (coma-separado si hay varios).
FRONTEND_URL=http://localhost:3000
